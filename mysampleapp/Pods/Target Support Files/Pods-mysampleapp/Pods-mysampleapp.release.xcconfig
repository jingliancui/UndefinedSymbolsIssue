CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/ShengwangAudio_iOS" "${PODS_ROOT}/ShengwangInfra_iOS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/AIAEC" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/AIAECLL" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/AINS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/AINSLL" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/AudioBeauty" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/LipSync" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/RtcBasic" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangAudio_iOS/SpatialAudio" "${PODS_XCFRAMEWORKS_BUILD_DIR}/ShengwangInfra_iOS"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
OTHER_LDFLAGS = $(inherited) -framework "AgoraAiEchoCancellationExtension" -framework "AgoraAiEchoCancellationLLExtension" -framework "AgoraAiNoiseSuppressionExtension" -framework "AgoraAiNoiseSuppressionLLExtension" -framework "AgoraAudioBeautyExtension" -framework "AgoraLipSyncExtension" -framework "AgoraRtcKit" -framework "AgoraSoundTouch" -framework "AgoraSpatialAudioExtension" -framework "Agorafdkaac" -framework "Agoraffmpeg" -framework "aosl" -weak_framework "AgoraAiEchoCancellationExtension" -weak_framework "AgoraAiEchoCancellationLLExtension" -weak_framework "AgoraAiNoiseSuppressionExtension" -weak_framework "AgoraAiNoiseSuppressionLLExtension" -weak_framework "AgoraAudioBeautyExtension" -weak_framework "AgoraLipSyncExtension" -weak_framework "AgoraRtcKit" -weak_framework "AgoraSoundTouch" -weak_framework "AgoraSpatialAudioExtension" -weak_framework "Agorafdkaac" -weak_framework "Agoraffmpeg" -weak_framework "aosl"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/ShengwangAudio_iOS" "-F${PODS_CONFIGURATION_BUILD_DIR}/ShengwangInfra_iOS"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
